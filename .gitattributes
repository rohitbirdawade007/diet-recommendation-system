# Normalize line endings automatically
* text=auto

# Force LF for source files
*.py   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.txt  text eol=lf

# Binary files
*.pkl  binary
*.png  binary
*.jpg  binary
*.ico  binary
*.h5   binary
